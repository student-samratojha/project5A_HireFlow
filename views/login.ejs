<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Login - Interview Portal</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-[#1e1e1e] text-[#f5f5f7] min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md bg-[#2d2d2d]/80 backdrop-blur-xl border border-[#ffffff10] rounded-3xl p-8 shadow-2xl">
        <h2 class="text-2xl font-bold mb-6 text-center">Sign In</h2>
        
        <form action="/auth/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Email Address</label>
                <input type="email" name="email" required 
                    class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white transition-all">
            </div>
            
            <div>
                <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Password</label>
                <input type="password" name="password" required 
                    class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white transition-all">
            </div>

            <button type="submit" 
                class="w-full bg-[#007aff] hover:bg-[#0062cc] text-white py-3 rounded-xl font-semibold transition-all shadow-lg mt-2">
                Login
            </button>
        </form>

        <p class="mt-8 text-center text-sm text-[#a1a1a6]">
            Don't have an account? 
            <a href="/auth/register" class="text-[#007aff] hover:underline">Register here</a> | <a href="/"class="text-[#007aff] hover:underline">Home</a>
        </p>
    </div>
</body>
</html>