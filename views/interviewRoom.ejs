<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Interview Room</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-[#1e1e1e] text-[#f5f5f7] min-h-screen p-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Candidate Profile -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-[#2d2d2d] rounded-3xl p-8 border border-[#ffffff10] shadow-xl text-center">
                <!-- Note: Ensure controller populates 'candidate' in getInterviewRoom -->
                <img src="<%= interview.candidate.profileImage %>" class="w-32 h-32 rounded-3xl mx-auto mb-6 object-cover border-4 border-[#3a3a3c]">
                <h2 class="text-2xl font-bold"><%= interview.candidate.name %></h2>
                <p class="text-[#007aff] font-bold uppercase text-xs tracking-widest mb-4"><%= interview.position %></p>
                <div class="flex flex-wrap justify-center gap-2">
                    <% interview.candidate.skills.forEach(skill => { %>
                        <span class="bg-[#3a3a3c] px-3 py-1 rounded-lg text-xs font-medium"><%= skill %></span>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Interview Feedback -->
        <div class="lg:col-span-2">
            <div class="bg-[#2d2d2d] rounded-3xl p-8 border border-[#ffffff10] shadow-xl h-full">
                <h3 class="text-xl font-bold mb-6">Evaluation Notes</h3>
                <form action="/secure/updateStatusByInterviewer" method="POST" class="space-y-5">
                    <input type="hidden" name="id" value="<%= interview._id %>">
                    
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2">Technical Assessment</label>
                        <textarea name="notes" rows="8" class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-2xl px-4 py-4 resize-none" placeholder="Provide detailed feedback..."></textarea>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2">Status Recommendation</label>
                        <div class="grid grid-cols-3 gap-4">
                            <label class="flex flex-col items-center p-4 bg-[#3a3a3c] rounded-2xl cursor-pointer hover:ring-2 hover:ring-[#34c759] transition-all">
                                <input type="radio" name="status" value="Selected" class="hidden peer" required>
                                <span class="font-bold">Select</span>
                            </label>
                            <label class="flex flex-col items-center p-4 bg-[#3a3a3c] rounded-2xl cursor-pointer hover:ring-2 hover:ring-[#ffcc00] transition-all">
                                <input type="radio" name="status" value="Pending" class="hidden peer">
                                <span class="font-bold">Pending</span>
                            </label>
                            <label class="flex flex-col items-center p-4 bg-[#3a3a3c] rounded-2xl cursor-pointer hover:ring-2 hover:ring-[#ff3b30] transition-all">
                                <input type="radio" name="status" value="Rejected" class="hidden peer">
                                <span class="font-bold">Reject</span>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-[#007aff] py-4 rounded-2xl font-bold text-lg shadow-lg hover:bg-[#0062cc] transition-all">Submit Evaluation</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>