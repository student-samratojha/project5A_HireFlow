<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Interviewer Dashboard</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-[#1e1e1e] text-[#f5f5f7] min-h-screen">
    <nav class="bg-[#2d2d2d]/80 backdrop-blur-md border-b border-[#ffffff10] px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold tracking-tight">Interviewer <span class="text-[#34c759]">Hub</span></h1>
            <a href="/auth/logout" class="bg-[#3a3a3c] px-4 py-2 rounded-lg text-sm font-medium">Logout</a>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto p-6">
        <div class="bg-[#2d2d2d] rounded-3xl p-8 border border-[#ffffff10] shadow-xl">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-16 h-16 rounded-2xl bg-[#34c759]/20 flex items-center justify-center text-[#34c759]">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <div>
                    <h2 class="text-2xl font-bold">Welcome back, <%= interviewer.name %></h2>
                    <p class="text-[#a1a1a6]"><%= interviewer.department %> Department</p>
                </div>
            </div>

            <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-[#a1a1a6] text-xs">Interview Schedule</h3>
            <div class="space-y-4">
                <% if (typeof interview !== 'undefined' && interview.length > 0) { %>
                    <% interview.forEach(item => { %>
                        <div class="flex items-center justify-between p-6 bg-[#3a3a3c] rounded-2xl hover:bg-[#48484a] transition-all cursor-pointer">
                            <div class="flex items-center gap-4">
                                <img src="<%= item.candidate.profileImage %>" class="w-12 h-12 rounded-xl object-cover bg-[#1e1e1e]">
                                <div>
                                    <p class="font-bold"><%= item.candidate.name %></p>
                                    <p class="text-xs text-[#007aff] font-bold uppercase"><%= item.position %></p>
                                    <p class="text-xs text-[#a1a1a6]"><%= new Date(item.interviewDate).toLocaleString() %></p>
                                </div>
                            </div>
                            <%if(interview.interviewDate === new Date().toISOString()){%>
                                
                            <a href="/secure/interviewRoom/<%= item._id %>" class="bg-[#007aff] px-6 py-2 rounded-xl text-sm font-bold shadow-lg shadow-[#007aff]/20">Start Interview</a>
                            <%}else{%>
                                  <a href="/secure/interviewer?Start_Soon" class="bg-black px-6 py-2 rounded-xl text-sm font-bold shadow-lg shadow-black/20">Start Soon</a>
                                  <%}%>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </main>
</body>
</html>