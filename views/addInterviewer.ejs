<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Add Interviewer</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-[#1e1e1e] text-[#f5f5f7] min-h-screen p-6">
    <div class="max-w-xl mx-auto">
        <a href="/secure/admin" class="inline-flex items-center text-[#a1a1a6] hover:text-white mb-6">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"></path></svg>
            Back to Dashboard
        </a>
        
        <div class="bg-[#2d2d2d] border border-[#ffffff10] rounded-3xl p-8 shadow-2xl">
            <h2 class="text-2xl font-bold mb-8">Add New Interviewer</h2>
            
            <form action="/secure/addInterviewer" method="POST" class="space-y-4">
                <div class="grid grid-cols-1 gap-5">
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Full Name</label>
                        <input type="text" name="name" required class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3">
                    </div>
                    
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Email</label>
                        <input type="email" name="email" required class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Temporary Password</label>
                        <input type="password" name="password" required class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Department</label>
                        <select name="department" class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3">
                            <option value="Engineering">Engineering</option>
                            <option value="HR">HR</option>
                            <option value="Product">Product</option>
                            <option value="Design">Design</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Phone Number</label>
                        <input type="text" name="phone" class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Profile Image URL</label>
                        <input type="text" name="profilePic" placeholder="https://..." class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Skills (Comma separated)</label>
                        <input type="text" name="skills" placeholder="Node.js, React, MongoDB" class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-1 ml-1">Office/Home Address</label>
                        <textarea name="address" rows="2" class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white resize-none"></textarea>
                    </div>
                </div>

                <input type="hidden" name="role" value="interviewer">
                
                <button type="submit" 
                    class="w-full bg-[#007aff] hover:bg-[#0062cc] text-white py-4 rounded-xl font-bold transition-all shadow-lg mt-4">
                    Create Interviewer Profile
                </button>
            </form>
        </div>
    </div>
</body>
</html>