<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Schedule Interview - Admin</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    </style>
</head>
<body class="bg-[#1e1e1e] text-[#f5f5f7] min-h-screen p-6">
    <div class="max-w-2xl mx-auto">
        <a href="/secure/admin" class="inline-flex items-center text-[#a1a1a6] hover:text-white mb-6 transition-colors group">
            <svg class="w-4 h-4 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            Back to Dashboard
        </a>
        
        <div class="bg-[#2d2d2d]/80 backdrop-blur-xl border border-[#ffffff10] rounded-[2.5rem] p-10 shadow-2xl">
            <h2 class="text-3xl font-bold mb-2">Schedule Interview</h2>
            <p class="text-[#a1a1a6] mb-8">Assign a candidate to an interviewer and set the session details.</p>
            
            <form action="/secure/addCandidate" method="POST" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Select Candidate -->
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2 ml-1">Candidate</label>
                        <select name="candidate" required class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white appearance-none cursor-pointer">
                            <option value="" disabled selected>Select a candidate</option>
                            <% candidates.forEach(c => { %>
                                <option value="<%= c._id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Select Interviewer -->
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2 ml-1">Interviewer</label>
                        <select name="interviewer" required class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white appearance-none cursor-pointer">
                            <option value="" disabled selected>Assign interviewer</option>
                            <% interviewers.forEach(i => { %>
                                <option value="<%= i._id %>"><%= i.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Position -->
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2 ml-1">Target Position</label>
                        <input type="text" name="position" placeholder="e.g. Software Engineer" required 
                            class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white placeholder-[#636366]">
                    </div>

                    <!-- Experience -->
                    <div>
                        <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2 ml-1">Years of Exp.</label>
                        <input type="number" name="experience" min="0" required 
                            class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white">
                    </div>
                </div>

                <!-- Interview Date -->
                <div>
                    <label class="block text-xs font-semibold text-[#a1a1a6] uppercase mb-2 ml-1">Scheduled Date & Time</label>
                    <input type="datetime-local" name="interviewDate" required 
                        class="w-full bg-[#3a3a3c] border-none focus:ring-2 focus:ring-[#007aff] outline-none rounded-xl px-4 py-3 text-white">
                </div>

                <div class="pt-4">
                    <button type="submit" 
                        class="w-full bg-[#007aff] hover:bg-[#0062cc] text-white py-4 rounded-2xl font-bold text-lg shadow-lg transition-all transform active:scale-[0.98]">
                        Confirm Interview Schedule
                    </button>
                </div>
            </form>
        </div>
        
        <div class="mt-8 text-center">
            <p class="text-sm text-[#636366]">An audit log will be generated automatically for this action.</p>
        </div>
    </div>
</body>
</html>