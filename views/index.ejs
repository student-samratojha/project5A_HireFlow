<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.tailwindcss.com"></script>
<title>HireFlow Luxury</title>

<style>
body{
    font-family: -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:
    radial-gradient(circle at top left, rgba(0,122,255,0.08), transparent 30%),
    radial-gradient(circle at bottom right, rgba(175,82,222,0.08), transparent 30%),
    #000000;
}

.glass{
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border:1px solid rgba(255,255,255,0.06);
}

.soft-border{
    border:1px solid rgba(255,255,255,0.04);
}
</style>
</head>

<body class="text-white min-h-screen px-6 py-10 md:px-16">

<div class="max-w-7xl mx-auto space-y-14">

    <!-- Hero -->
    <section class="glass rounded-[38px] p-10 md:p-16 relative overflow-hidden shadow-2xl">

        <div class="absolute top-0 right-0 w-72 h-72 bg-blue-500/10 blur-[140px]"></div>
        <div class="absolute bottom-0 left-0 w-72 h-72 bg-purple-500/10 blur-[140px]"></div>

        <div class="relative z-10 text-center max-w-3xl mx-auto">

            <div class="w-24 h-24 mx-auto rounded-[28px] bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shadow-2xl shadow-blue-500/20 mb-8">
                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0v6a2 2 0 01-2 2H7a2 2 0 01-2-2v-6m14 0V9a2 2 0 00-2-2M7 11V9a2 2 0 012-2V5a2 2 0 012-2h2a2 2 0 012 2v2"/>
                </svg>
            </div>

            <h1 class="text-5xl md:text-7xl font-black tracking-tight bg-gradient-to-b from-white to-zinc-500 bg-clip-text text-transparent mb-6">
                HireFlow
            </h1>

            <p class="text-zinc-400 text-lg md:text-xl leading-relaxed mb-10">
                Intelligent recruitment ecosystem crafted for modern hiring teams, secure evaluations and premium workflow control.
            </p>

            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="/auth/login" class="px-10 py-4 bg-blue-600 rounded-2xl font-semibold hover:scale-105 transition shadow-xl shadow-blue-500/20">
                    Sign In
                </a>

                <a href="/auth/register" class="px-10 py-4 glass rounded-2xl font-semibold hover:bg-white/5 transition">
                    Create Account
                </a>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="grid md:grid-cols-3 gap-6">

        <div class="glass rounded-3xl p-8 hover:bg-white/[0.04] transition">
            <div class="w-14 h-14 rounded-2xl bg-green-500/10 flex items-center justify-center text-green-400 mb-6">
                ⚡
            </div>
            <h3 class="text-xl font-bold mb-3">Live Interview Engine</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">
                Premium live interview environment with instant decision controls and real-time notes.
            </p>
        </div>

        <div class="glass rounded-3xl p-8 hover:bg-white/[0.04] transition">
            <div class="w-14 h-14 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6">
                🔐
            </div>
            <h3 class="text-xl font-bold mb-3">Audit Security</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">
                Every administrative action logged for enterprise-grade transparency.
            </p>
        </div>

        <div class="glass rounded-3xl p-8 hover:bg-white/[0.04] transition">
            <div class="w-14 h-14 rounded-2xl bg-orange-500/10 flex items-center justify-center text-orange-400 mb-6">
                📅
            </div>
            <h3 class="text-xl font-bold mb-3">Smart Scheduling</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">
                AI-style structured slot allocation with role assignment.
            </p>
        </div>

    </section>

    <!-- Workflow -->
    <section class="space-y-6">

        <div class="flex items-center gap-4">
            <h2 class="text-2xl font-bold">Workflow</h2>
            <div class="h-px flex-1 bg-white/10"></div>
        </div>

        <div class="grid md:grid-cols-4 gap-5">

            <div class="glass rounded-3xl p-6 relative">
                <span class="absolute top-4 right-5 text-4xl text-white/5 font-black">01</span>
                <h4 class="text-blue-400 text-sm font-bold mb-2">REGISTER</h4>
                <p class="text-zinc-300 text-sm">Candidate builds profile and uploads credentials.</p>
            </div>

            <div class="glass rounded-3xl p-6 relative">
                <span class="absolute top-4 right-5 text-4xl text-white/5 font-black">02</span>
                <h4 class="text-purple-400 text-sm font-bold mb-2">ASSIGN</h4>
                <p class="text-zinc-300 text-sm">Admin links interviewer with candidate.</p>
            </div>

            <div class="glass rounded-3xl p-6 relative">
                <span class="absolute top-4 right-5 text-4xl text-white/5 font-black">03</span>
                <h4 class="text-green-400 text-sm font-bold mb-2">INTERVIEW</h4>
                <p class="text-zinc-300 text-sm">Live session and structured evaluation.</p>
            </div>

            <div class="glass rounded-3xl p-6 relative">
                <span class="absolute top-4 right-5 text-4xl text-white/5 font-black">04</span>
                <h4 class="text-red-400 text-sm font-bold mb-2">RESULT</h4>
                <p class="text-zinc-300 text-sm">Instant status publication and feedback.</p>
            </div>

        </div>
    </section>

    <!-- Footer Stats -->
    <section class="glass rounded-3xl p-8 grid md:grid-cols-3 text-center">

        <div class="border-r border-white/5">
            <h3 class="text-xl font-bold">Admin</h3>
            <p class="text-zinc-400 text-sm">Full access & control</p>
        </div>

        <div class="border-r border-white/5">
            <h3 class="text-xl font-bold">Interviewer</h3>
            <p class="text-zinc-400 text-sm">Evaluate candidates</p>
        </div>

        <div>
            <h3 class="text-xl font-bold">Candidate</h3>
            <p class="text-zinc-400 text-sm">Track hiring journey</p>
        </div>

    </section>

</div>

</body>
</html>