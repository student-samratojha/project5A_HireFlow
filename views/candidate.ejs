<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>HireFlow Portal</title>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background:
            radial-gradient(circle at top left, rgba(0,122,255,0.08), transparent 30%),
            radial-gradient(circle at bottom right, rgba(175,82,222,0.08), transparent 30%),
            #000000;
        }
        .glass {
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.06);
        }
    </style>
</head>
<body class="text-white min-h-screen p-6 md:p-12">
    <div class="max-w-4xl mx-auto space-y-12">
        <!-- Header Profile Card -->
        <div class="glass rounded-[3rem] p-10 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-24 bg-gradient-to-r from-[#af52de] to-[#5856d6] opacity-20"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row items-center gap-8">
                <img src="<%= candidate.profileImage %>" class="w-32 h-32 rounded-[2rem] border-4 border-black/50 shadow-2xl object-cover">
                <div class="text-center md:text-left flex-1">
                    <h1 class="text-4xl font-bold mb-1"><%= candidate.name %></h1>
                    <p class="text-zinc-400 text-lg mb-4"><%= candidate.email %></p>
                    <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                        <% candidate.skills.forEach(skill => { %>
                            <span class="px-3 py-1 glass rounded-xl text-xs font-semibold text-[#007aff]"><%= skill %></span>
                        <% }) %>
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <a href="/auth/logout" class="glass hover:bg-white/5 px-6 py-2 rounded-2xl text-sm font-semibold transition-all">Sign Out</a>
                </div>
            </div>
        </div>

        <!-- Interview Schedule Section -->
        <div class="glass rounded-[3rem] p-10 shadow-2xl">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-2xl font-bold flex items-center">
                    <span class="w-2 h-6 bg-[#007aff] rounded-full mr-3"></span>
                    My Interview Schedule
                </h2>
            </div>

            <div class="space-y-4">
                <% if (interview && interview.length > 0) { %>
                    <% interview.forEach(item => { %>
                        <div class="flex flex-col md:flex-row items-center justify-between p-8 glass rounded-[2.5rem] hover:bg-white/[0.04] transition-all">
                            <div class="mb-4 md:mb-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-bold text-[#007aff] uppercase tracking-widest"><%= item.position %></span>
                                    <span class="text-zinc-600">•</span>
                                    <span class="text-xs text-zinc-400 font-medium"><%= item.experience %> Yrs Exp.</span>
                                </div>
                                <p class="text-lg font-bold">Interviewer: <%= item.interviewer ? item.interviewer.name : 'Awaiting Assignment' %></p>
                                <div class="flex items-center gap-2 text-sm text-zinc-500 mt-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    <span><%= new Date(item.interviewDate).toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                                    <span class="ml-2 font-mono"><%= new Date(item.interviewDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                                </div>
                            </div>
                            
                            <div class="flex items-center gap-4">
                                <div class="text-right">
                                    <span class="px-6 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest glass
                                        <%= item.status === 'Pending' ? 'text-[#ffcc00] border-[#ffcc00]/20' : '' %>
                                        <%= item.status === 'Selected' ? 'text-[#34c759] border-[#34c759]/20' : '' %>
                                        <%= item.status === 'Rejected' ? 'text-[#ff3b30] border-[#ff3b30]/20' : '' %>">
                                        <%= item.status %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-20 glass rounded-[2.5rem] border-dashed">
                        <p class="text-zinc-400 text-lg">You have no interviews scheduled at this time.</p>
                        <p class="text-zinc-600 text-sm mt-1">Check back later or contact HR for updates.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>